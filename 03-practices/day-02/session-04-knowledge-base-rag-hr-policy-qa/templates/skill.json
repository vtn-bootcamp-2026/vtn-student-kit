    "network_access": true
  },
  "required_files": {
    "config": "skill.json",
    "instructions": "SKILL.md",
    "schema": "schemas/hr-response.schema.json",
    "knowledge_base": ["kb/kb-inventory.md", "kb/hr-policies/"],
    "scripts": ["scripts/chunker.py", "scripts/retriever.py", "scripts/evaluator.py"]
  },
  "quality_gates": {
    "min_in_scope_accuracy": ">=75%",
    "out_of_scope_refusal": "100%",
    "citation_rate": ">=90%",
    "no_hallucinated_citations": "100%",
    "self_check_success": ">=80%",
    "skill_package_completeness": "8/8 files"
  }
