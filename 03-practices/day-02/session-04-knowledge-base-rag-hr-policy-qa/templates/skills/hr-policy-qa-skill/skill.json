{
  "name": "hr-policy-qa-skill",
  "version": "1.0.0",
  "description": "Agentic RAG Skill: Tro ly hoi dap chinh sach nhan su tu tri voi trich dan nguon va tu kiem duyet",
  "author": "Viettel Network AI Builders Bootcamp",
  "created_at": "2026-05-27",
  "triggers": {
    "keywords": ["nghi phep", "phu cap", "tham nien", "dao tao", "chinh sach", "nhan su", "HR", "nghi", "tro cap", "thuong"],
    "question_patterns": [
      "Cau hoi ve quyen loi nhan vien",
      "Hoi ve quy dinh nhan su",
      "Cau hoi ve che do HR"
    ]
  },
  "permissions": {
    "read_files": [
      "kb/hr-policies/*.md",
      "kb/kb-inventory.md"
    ],
    "write_files": [],
    "execute_scripts": [
      "scripts/chunker.py",
      "scripts/retriever.py",
      "scripts/evaluator.py"
    ],
    "network_access": true
  },
  "required_files": {
    "config": "skill.json",
    "instructions": "SKILL.md",
    "schema": "schemas/hr-response.schema.json",
    "knowledge_base": [
      "kb/kb-inventory.md",
      "kb/hr-policies/"
    ],
    "scripts": [
      "scripts/chunker.py",
      "scripts/retriever.py",
      "scripts/evaluator.py"
    ]
  },
  "quality_gates": {
    "min_in_scope_accuracy": ">=75% (6/8)",
    "out_of_scope_refusal": "100% (2/2)",
    "citation_rate": ">=90%",
    "no_hallucinated_citations": "100%",
    "self_check_success": ">=80%",
    "skill_package_completeness": "8/8 files",
    "cross_team_run": ">=1 other team"
  }
}
