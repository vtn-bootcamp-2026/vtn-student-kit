{
  "name": "contract-term-extractor",
  "version": "1.0.0",
  "description": "Kỹ năng trích xuất điều khoản hợp đồng viễn thông, phát hiện cờ đỏ và định tuyến HITL",
  "author": "<tên nhóm>",
  "created_at": "<YYYY-MM-DD>",

  "triggers": {
    "file_patterns": [".docx", ".txt", ".pdf"],
    "keywords": ["rà soát hợp đồng", "trích xuất điều khoản", "kiểm tra cờ đỏ", "contract review"],
    "description": "Kích hoạt khi người dùng gửi file hợp đồng hoặc yêu cầu rà soát"
  },

  "permissions": {
    "read_files": true,
    "write_files": ["outputs/", "logs/"],
    "execute_scripts": ["scripts/intake.py", "scripts/validator.py", "scripts/router.py"],
    "network_access": false,
    "description": "Chỉ đọc file đầu vào, ghi output/logs, chạy script nội bộ. Không truy cập mạng."
  },

  "required_files": {
    "config": "skill.json",
    "instructions": "SKILL.md",
    "schema": "schemas/contract-term.schema.json",
    "knowledge_base": [
      "kb/clause-library.md",
      "kb/red-flag-rules.md"
    ],
    "scripts": [
      "scripts/intake.py",
      "scripts/validator.py",
      "scripts/router.py"
    ]
  },

  "quality_gates": {
    "min_test_pass_rate": 0.75,
    "hitl_coverage": 1.0,
    "source_evidence_required": true,
    "schema_compliance": 1.0,
    "no_real_data": true
  }
}
