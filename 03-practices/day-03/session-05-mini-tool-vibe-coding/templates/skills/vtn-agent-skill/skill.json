{
  "name": "vtn-agent-skill",
  "version": "1.0.0",
  "description": "VTN Internal Agent Skill - Trợ lý AI nội bộ sử dụng Hermes Agent với Ollama local",
  "author": "{Tên nhóm}",
  "created_at": "{Ngày}",
  "triggers": {
    "file_patterns": [".md", ".txt", ".csv"],
    "keywords": ["tra cứu", "quy trình", "cấu hình", "vận hành", "sự cố", "BGP", "OSPF", "router"],
    "anti_triggers": ["thực hiện ngay", "xóa", "format", "delete", "erase"]
  },
  "permissions": {
    "read_files": true,
    "write_files": [],
    "execute_scripts": ["scripts/hook-block-write.py"],
    "network_access": false
  },
  "required_files": {
    "config": "skill.json",
    "instructions": "SKILL.md",
    "schema": "schemas/agent-response.schema.json",
    "knowledge_base": ["kb/"],
    "scripts": ["scripts/hook-block-write.py"]
  },
  "quality_gates": {
    "min_test_pass_rate": ">=6/8 behavioral tests",
    "hook_enforcement": "write_file và terminal bị block",
    "no_real_data": true,
    "memory_clear_protocol": true
  },
  "agent_profiles": {
    "tri-thuc-noi-bo": {
      "soul_file": "SOUL.md",
      "mode": "read-only",
      "kb_path": "kb/",
      "hook": "scripts/hook-block-write.py"
    },
    "soan-thao-noi-dung": {
      "soul_file": "SOUL.md",
      "mode": "draft-only",
      "kb_path": "kb/"
    },
    "checklist-van-hanh": {
      "soul_file": "SOUL.md",
      "mode": "planning-only",
      "kb_path": "kb/"
    }
  }
}
