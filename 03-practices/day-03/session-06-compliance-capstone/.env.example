# ==============================================================================
# CẤU HÌNH BIẾN MÔI TRƯỜNG - MINI TOOL ANONYMIZER (SESSION 06 CAPSTONE)
# Hướng dẫn: Đổi tên tệp này thành '.env' và điền các thông số tương ứng.
# ==============================================================================

# 1. CẤU HÌNH CLOUD API (Dành cho phiên bản: anonymizer-solution-gemini.py)
# Khóa API Google Gemini. Lấy khóa tại Google AI Studio nếu chạy thử nghiệm online.
# CẢNH BÁO: Không chia sẻ khóa này lên các kho lưu trữ mã nguồn công khai (Git).
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# 2. CẤU HÌNH LOCAL LLM (Dành cho phiên bản chạy offline: anonymizer-solution.py)
# Đường dẫn API endpoint của máy chủ Ollama cục bộ
OLLAMA_ENDPOINT=http://localhost:11434/v1/chat/completions

# Tên mô hình cục bộ được sử dụng (Tháng 5/2026)
# - RAM 8GB: Khuyến nghị "gemma4:e2b" hoặc "qwen3.5:1.5b-instruct"
# - RAM >= 16GB: Khuyến nghị "qwen3.5:7b-instruct" hoặc "gemma4:e4b"
LOCAL_MODEL_NAME=gemma4:e2b
